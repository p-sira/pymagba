{
    "version": 1,
    "project": "pymagba",
    "project_url": "https://github.com/p-sira/pymagba",
    "repo": ".",
    "branches": [
        "main",
        "dev"
    ],
    "environment_type": "virtualenv",
    "env_dir": ".asv/env",
    "results_dir": ".asv/results",
    "html_dir": ".asv/html",
    "benchmark_dir": "benchmarks",
    "pythons": [
        "3.12"
    ],
    "matrix": {
        "req": {
            "numpy": "",
            "scipy": ""
        }
    },
    "build_command": [
        "python -m pip install maturin",
        "maturin build --release --strip --out {build_cache_dir}"
    ],
    "install_command": [
        "python -m pip install {wheel_file}"
    ],
    "uninstall_command": [
        "python -m pip uninstall -y pymagba"
    ]
}